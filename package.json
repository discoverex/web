{
  "name": "web",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "dotenv -e .env -- turbo run dev --ui=stream",
    "dev:game": "turbo run dev --filter=game-hub --ui=stream",
    "dev:discoverex": "turbo run dev --filter=discoverex --ui=stream",
    "dev:magiceye": "turbo run dev --filter=magic-eye --ui=stream",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.11",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
